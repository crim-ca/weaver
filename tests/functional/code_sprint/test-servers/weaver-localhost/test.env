# Followng server configuration considers that "config/weaver.ini" (a copy of the "weaver.ini.example") is employed
TEST_SERVER=weaver-localhost
TEST_SERVER_BASE_URL="http://localhost:4001"
TEST_SERVER_REQUEST_TIMEOUT=10
# FIXME: to enable with https://github.com/crim-ca/weaver/issues/18, https://github.com/crim-ca/weaver/pull/548
TEST_SERVER_RESULTS_SINGLE_OUTPUT=false
# FIXME: to enable with https://github.com/crim-ca/weaver/issues/873
TEST_SERVER_OAP_DRU_OGCAPPPKG_UNSUPPORTED=true
